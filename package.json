{
  "name": "pgxsinkit",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build:public-packages": "bun scripts/build-public-packages.ts",
    "db:generate": "drizzle-kit generate --config=infra/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=infra/drizzle.config.ts",
    "db:push": "drizzle-kit push --config=infra/drizzle.config.ts",
    "dev:api": "cd apps/write-api && bun run dev",
    "dev:web": "cd apps/web && bun run dev",
    "format": "oxfmt --config .oxfmtrc.jsonc .",
    "format-check": "oxfmt --config .oxfmtrc.jsonc --check .",
    "guard:tmp-files": "bun scripts/check-temp-file-placement.ts",
    "infra:down": "bun scripts/infra-down.ts",
    "infra:up": "bun scripts/infra-up.ts",
    "lint": "oxlint -c .oxlintrc.jsonc apps/*/src packages/*/src scripts tests *.ts",
    "lint-check": "bun run lint",
    "perf:lab": "bun scripts/run-perf-lab.ts",
    "release:public:dry-run": "bun run build:public-packages && bun scripts/release-public-dry-run.ts",
    "release:public:publish": "bun run build:public-packages && bun scripts/publish-public-packages.ts --tag next",
    "release:public:publish:latest": "bun run build:public-packages && bun scripts/publish-public-packages.ts --tag latest",
    "sync:function:generate": "bun packages/server/src/cli/generate.ts --registry packages/schema/src/registry.ts --project-dir . --config infra/drizzle.config.ts",
    "test": "bun run test:unit && bun run test:integration",
    "test:integration": "bun run test:integration:contract && bun run test:integration:implementation",
    "test:integration:contract": "bun scripts/run-integration-suite.ts tests/integration/client-contract.integration.test.ts tests/integration/server-contract.integration.test.ts",
    "test:integration:implementation": "bun scripts/run-integration-suite.ts tests/integration/electric-pglite-sync.integration.test.ts tests/integration/write-api.integration.test.ts",
    "test:performance": "bun scripts/run-performance-suite.ts tests/performance/client-local-optimistic.perf.test.ts tests/performance/client-concurrent-mixed-load.perf.test.ts tests/performance/artifact-write-load.perf.test.ts",
    "test:performance:client": "bun scripts/run-performance-suite.ts tests/performance/client-local-optimistic.perf.test.ts",
    "test:performance:concurrent": "bun scripts/run-performance-suite.ts tests/performance/client-concurrent-mixed-load.perf.test.ts",
    "test:performance:concurrent:matrix": "bun scripts/run-concurrent-test-matrix.ts",
    "test:performance:server": "bun scripts/run-performance-suite.ts tests/performance/artifact-write-load.perf.test.ts",
    "test:unit": "vitest run tests/unit",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "validate": "bun run guard:tmp-files && bun run format && bun run format-check && bun run lint-check && bun run typecheck && bun run test",
    "version:public-packages": "bun scripts/update-public-package-versions.ts"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.4.5",
    "@electric-sql/pglite-prepopulatedfs": "0.0.3",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260511.1",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.6",
    "drizzle-kit": "1.0.0-rc.2",
    "hono": "4.12.18",
    "oxfmt": "0.49.0",
    "oxlint": "1.64.0",
    "oxlint-tsgolint": "0.22.1",
    "postgres": "3.4.9",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tsx": "4.21.0",
    "vite": "8.0.12",
    "vitest": "4.1.6",
    "zod": "4.4.3"
  },
  "packageManager": "bun@1.3.13"
}
