{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "types": ["node", "bun-types"]
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "scripts/**/*.ts",
    "tests/**/*.ts",
    "infra/**/*.ts",
    "drizzle.config.ts"
  ],
  "exclude": [
    "apps/web/src/App.tsx",
    "apps/web/src/main.tsx",
    "apps/perf-lab/src/App.tsx",
    "apps/perf-lab/src/main.tsx",
    "apps/docs"
  ]
}
