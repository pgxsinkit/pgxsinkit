{
  "printWidth": 120,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "sortImports": {
    "newlinesBetween": true,
    "internalPattern": ["@pgxsinkit/"],
  },
  "sortPackageJson": {
    "sortScripts": true,
  },
  "ignorePatterns": ["coverage/**", "dist/**", "node_modules/**", "tmp/**"],
  "useTabs": false,
  "tabWidth": 2,
  "insertFinalNewline": true,
  "bracketSpacing": true,
}
