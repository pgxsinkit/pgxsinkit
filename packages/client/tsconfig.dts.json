{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "rootDir": "src",
    "outDir": "dist",
    "types": ["node", "bun-types"],
    "paths": {
      "drizzle-orm": ["../../node_modules/drizzle-orm"],
      "drizzle-orm/*": ["../../node_modules/drizzle-orm/*"],
      "@pgxsinkit/contracts": ["../contracts/dist/index.d.ts"],
      "@pgxsinkit/pglite-sync": ["../pglite-sync/dist/index.d.ts"]
    }
  },
  "include": ["src"]
}
