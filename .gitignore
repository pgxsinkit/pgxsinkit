# starlight-typedoc generated API reference (regenerated on every docs build)
apps/docs/src/content/docs/api/
.env
# Real Supabase Cloud + Electric Cloud credentials for the cloud board demo (board ADR-0008) — never
# commit. Copy from board.cloud.env.example.
board.cloud.env
# CI-written GitHub Packages auth (publish side) — never commit a token
.npmrc
# Playwright browser-lane output (traces, last-run) — regenerated by `bun run test:integration:worker`
test-results/
playwright-report/