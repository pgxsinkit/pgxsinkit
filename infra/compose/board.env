# ───────────────────────────────────────────────────────────────────────────────────────────────
#  Board demo stack — environment (DEMO DEFAULTS, NOT SECRETS)
# ───────────────────────────────────────────────────────────────────────────────────────────────
#  Throwaway LOCAL values to bring up a one-command demo cluster. They grant nothing of value and
#  MUST be rotated for any non-local use. The board demo runs Supabase's NEW asymmetric auth (board
#  ADR-0007): GoTrue SIGNS sessions ES256 (GOTRUE_JWT_KEYS) and the board edge functions verify them
#  ES256-only via JWKS, with the new opaque `sb_publishable_`/`sb_secret_` API keys — no HS256 in the
#  board's auth path, no legacy anon/service_role JWT. (GoTrue still requires a symmetric JWT_SECRET to
#  boot — a real Cloud project carries one too — but signs ES256 and the board never verifies with it.)
#  Regenerate the asymmetric keyset with `bun scripts/gen-board-demo-keys.ts`. To run against real
#  cloud Supabase + Electric Cloud, use `board.cloud.env` (board ADR-0008), not this file.
#
#  Consumed by `bun run infra:up` (passed to podman compose via --env-file).
# ───────────────────────────────────────────────────────────────────────────────────────────────

# Postgres superuser password (applies to the `postgres` role — the image's default POSTGRES_USER).
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password
POSTGRES_DB=postgres

# Session-token lifetime (seconds) GoTrue stamps on issued access tokens.
JWT_EXPIRY=3600

# GoTrue REQUIRES this env to boot (the `Secret` config key is `required:"true"` even in v2.192) — but
# with GOTRUE_JWT_KEYS set it is NEVER converted to a key, added to the JWKS, or used to sign/verify
# (GoTrue's ApplyDefaults only falls back to the secret when Keys is empty). It is a required-but-unused
# placeholder: there is NO symmetric key in the keyset or the published JWKS, and the board verifies
# ES256-only. This is the closest to "zero symmetric" GoTrue allows. Throwaway/local.
JWT_SECRET=board-demo-unused-placeholder-min-32-characters-xx

# ── Asymmetric signing key — ASYMMETRIC ONLY (board ADR-0007) ─────────────────────────────────────
# A JSON array with a SINGLE EC signing JWK (key_ops includes "sign", or GoTrue reports "no signing
# key detected"). There is deliberately NO symmetric `oct` key here, so the keyset and the published
# JWKS (/auth/v1/.well-known/jwks.json) are asymmetric only — no symmetric key material anywhere.
# GoTrue signs every session ES256 with this key; the board edge functions verify against the JWKS
# (_shared/auth.ts); the two internal role JWTs the Envoy gateway swaps in (board/envoy.yaml) are
# signed with this SAME key, so they verify against the same JWKS.
GOTRUE_JWT_KEYS=[{"kty":"EC","kid":"board-demo-es256","use":"sig","key_ops":["sign","verify"],"alg":"ES256","ext":true,"crv":"P-256","x":"E-ojZGYJNkt5_x9cMfoCwRPMUlFW2sOqmzumC_5zcys","y":"oJiPjIrY3O4Rr3EaFnaOw8gn2ZkRDyjlALAj6a_5Pag","d":"H9VQEGODrDB3nIHXNllN-rPownka9zYQjQVR7VZEMII"}]

# ── New opaque API keys (board ADR-0007) ─────────────────────────────────────────────────────────
# Replace the legacy anon/service_role JWTs. The browser sends the publishable key as `apikey`; the
# seed sends the secret key to the GoTrue admin API. The local Kong pre-function (board/kong.yml)
# translates each into the matching internal role JWT — exactly as the Supabase Cloud gateway does —
# so the same client/seed code runs locally and on Cloud. These two strings are also hard-coded in
# board/kong.yml (Kong cannot read env); keep them in sync.
BOARD_PUBLISHABLE_KEY=sb_publishable_boarddemoLOCALxxxxxxxxx_demo0000
BOARD_SECRET_KEY=sb_secret_boarddemoLOCALxxxxxxxxxxxxxxx_demo0000

# External origin the browser reaches the gateway on (Kong → 54331). API_EXTERNAL_URL for GoTrue.
BOARD_API_EXTERNAL_URL=http://localhost:54331

# Where the board's Vite client runs (CORS + GoTrue redirect allow-list).
BOARD_SITE_URL=http://localhost:5173
