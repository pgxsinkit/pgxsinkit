# ───────────────────────────────────────────────────────────────────────────────────────────────
#  Board demo stack — environment (DEMO DEFAULTS, NOT SECRETS)
# ───────────────────────────────────────────────────────────────────────────────────────────────
#  Every value below is a PUBLIC Supabase self-hosted default, published in Supabase's own docs. The
#  anon/service keys are the demo JWTs signed with the demo JWT secret. They exist only to bring up a
#  throwaway LOCAL cluster with one command. They grant nothing of value and MUST be rotated for any
#  non-local use. Committing them is consistent with the harness compose, which commits its demo
#  Postgres password (infra/compose/docker-compose.yml).
#
#  Consumed by `bun run infra:board:up` (passed to podman compose via --env-file).
# ───────────────────────────────────────────────────────────────────────────────────────────────

# Postgres superuser (the supabase/postgres image's admin role).
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password
POSTGRES_DB=postgres

# GoTrue / PostgREST / Edge functions all verify HS256 tokens with this shared secret.
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# The published Supabase demo anon / service_role JWTs (role-only claims, signed with JWT_SECRET).
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTc5OTUzNTYwMH0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UtZGVtbyIsImlhdCI6MTY0MTc2OTIwMCwiZXhwIjoxNzk5NTM1NjAwfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q

# External origin the browser reaches the gateway on (Kong → 54331). API_EXTERNAL_URL for GoTrue.
BOARD_API_EXTERNAL_URL=http://localhost:54331

# Where the board's Vite client runs (CORS + GoTrue redirect allow-list).
BOARD_SITE_URL=http://localhost:5173
